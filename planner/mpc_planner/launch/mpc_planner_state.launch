<?xml version="1.0"?>
<!--
  ### HJ : State-aware MPC planner (single-instance template).

  One instance = one (state, output_topic) pair.
    state:=overtake  → publishes OTWpntArray on <output_topic or ~out/otwpnts>
    state:=recovery  → publishes   WpntArray on <output_topic or ~out/wpnts>
    state:=observe   → no role output, debug-only (Path + WpntArray mirror)

  Observation-first (Phase 1~6):
    attach_to_statemachine:=false (default)
      → role outputs remap to the *_observation topics, state_machine keeps
        consuming the legacy spliner/recovery_spliner. MPC is listen-only.
    attach_to_statemachine:=true (Phase X gate — after metrics pass)
      → role outputs remap to the real /planner/avoidance/otwpnts or
        /planner/recovery/wpnts, and 3d_headtohead.launch is adjusted to stop
        launching the legacy spliner counterparts.

  Solver params come from config/mpcc_params.yaml (Phase 1 placeholder). Phase
  3 will branch config per state (state_{observe,overtake,recovery}.yaml).
-->
<launch>
  <arg name="state"                 default="observe"
       doc="overtake | recovery | observe | auto  (auto = Phase X refactored 2-state FSM)"/>
  <arg name="use_pred_variance"     default="True"
       doc="When true, inflate sigma_s_obs/sigma_n_obs per tick using the predictor's vs_var/vd_var over horizon. Makes the bubble wider when prediction is uncertain."/>
  <!-- ### HJ : Default includes an `mpc_` prefix so standalone launch does
       NOT collide with other backends (sampling_planner_state.launch uses
       /overtake as well — same default would kick each other off the master
       with "new node registered with same name"). multi.launch overrides
       instance_name explicitly inside <group ns="mpc_planner"> so node
       names there still become /mpc_planner/overtake etc. -->
  <arg name="instance_name"         default="mpc_$(arg state)"/>
  <!-- ### HJ : Phase X — state:=auto reuses state_overtake.yaml by default
       (it is a superset of OVERTAKE tuning; RECOVERY currently uses quintic
       primary so NLP-side tuning is shared). Override for NLP recovery tuning.  -->
  <arg name="config_file"           default="$(find mpc_planner)/config/state_$(arg state).yaml"
       if="$(eval arg('state') != 'auto')"
       doc="Default resolves to state_{overtake,recovery,observe}.yaml. Override with an absolute path to run, e.g., the overtake preset in observe-mode for safe tuning:
            config_file:=$(find mpc_planner)/config/state_overtake.yaml state:=observe"/>
  <arg name="config_file"           default="$(find mpc_planner)/config/state_overtake.yaml"
       if="$(eval arg('state') == 'auto')"/>
  <arg name="attach_to_statemachine" default="false"
       doc="Phase X gate. false (default) → role output remapped to *_observation; true → real topic."/>
  <arg name="output_topic"          default=""
       doc="When non-empty, overrides the role-specific topic remap entirely."/>

  <!-- ### HJ : debug_log — per-tick CSV + on-anomaly NPZ. Leave enable=false
       for normal runs; flip true when diagnosing trajectory quality issues.
       Output lands in $(find mpc_planner)/debug_log/runs/<timestamp>_.../
       (gitignored). -->
  <!-- ### HJ : solver backend.
       `frenet_kin` (default, 2026-04-20 redesign) — Frenet kinematic bicycle
           MPC. State [n, mu, v], hard corridor with wall_safe + inflation,
           half-plane obstacle constraint, external SideDecider with
           5-tick hysteresis. See src/frenet_kin_solver.py.
       `frenet_d` — legacy n(s)-perturbation MPCC (hard corridor box but
           cost-only smoothness → tick jitter + wall-hug).
       `xy` — original kinematic bicycle MPCC (rollback path). -->
  <arg name="solver_backend"              default="frenet_kin"
       doc="frenet_kin | frenet_d | xy"/>

  <arg name="debug_log_enable"            default="false"/>
  <arg name="debug_log_dir"               default="$(find mpc_planner)/debug_log/runs"/>
  <arg name="debug_log_tier_b"            default="on_anomaly"
       doc="never | every_n | on_anomaly | always"/>
  <arg name="debug_log_every_n"           default="10"/>
  <arg name="debug_log_anomaly_kappa_max" default="3.0"/>

  <node pkg="mpc_planner"
        type="mpc_planner_state_node.py"
        name="$(arg instance_name)"
        output="screen">
    <rosparam command="load" file="$(arg config_file)"/>
    <param name="state" value="$(arg state)"/>
    <param name="solver_backend" value="$(arg solver_backend)"/>
    <param name="use_pred_variance" value="$(arg use_pred_variance)"/>
    <param name="debug_log_enable"            value="$(arg debug_log_enable)"/>
    <param name="debug_log_dir"               value="$(arg debug_log_dir)"/>
    <param name="debug_log_tier_b"            value="$(arg debug_log_tier_b)"/>
    <param name="debug_log_every_n"           value="$(arg debug_log_every_n)"/>
    <param name="debug_log_anomaly_kappa_max" value="$(arg debug_log_anomaly_kappa_max)"/>

    <!-- Role-specific topic remap.
         Priority: explicit output_topic > attach_to_statemachine flag > *_observation default. -->

    <!-- Explicit override (highest priority) -->
    <remap from="~out/otwpnts" to="$(arg output_topic)"
           if="$(eval arg('output_topic') != '' and arg('state') == 'overtake')"/>
    <remap from="~out/wpnts"   to="$(arg output_topic)"
           if="$(eval arg('output_topic') != '' and arg('state') == 'recovery')"/>

    <!-- attach_to_statemachine:=true → real state_machine topic -->
    <remap from="~out/otwpnts" to="/planner/avoidance/otwpnts"
           if="$(eval arg('output_topic') == '' and arg('state') == 'overtake' and arg('attach_to_statemachine'))"/>
    <remap from="~out/wpnts"   to="/planner/recovery/wpnts"
           if="$(eval arg('output_topic') == '' and arg('state') == 'recovery' and arg('attach_to_statemachine'))"/>

    <!-- Default (attach_to_statemachine:=false) → _observation suffix -->
    <remap from="~out/otwpnts" to="/planner/avoidance/otwpnts_observation"
           if="$(eval arg('output_topic') == '' and arg('state') == 'overtake' and not arg('attach_to_statemachine'))"/>
    <remap from="~out/wpnts"   to="/planner/recovery/wpnts_observation"
           if="$(eval arg('output_topic') == '' and arg('state') == 'recovery' and not arg('attach_to_statemachine'))"/>

    <!-- ### HJ : Phase X (refactored) — unified MPC output topic.
         One pub for all roles (overtake / recovery / auto). attach_to_statemachine
         toggles between the real and _observation suffix. SM fork subscribes
         to /planner/mpc/wpnts; legacy SM nodes are untouched. -->
    <remap from="~out/mpc_wpnts" to="/planner/mpc/wpnts"
           if="$(arg attach_to_statemachine)"/>
    <remap from="~out/mpc_wpnts" to="/planner/mpc/wpnts_observation"
           unless="$(arg attach_to_statemachine)"/>
  </node>
</launch>
