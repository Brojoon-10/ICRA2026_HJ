<?xml version="1.0"?>
<!-- ## IY : rolling-horizon SQP overtake, mpc_planner_state.launch-style.
     attach_to_statemachine:=false (default) -> observation topic only. -->
<launch>
  <arg name="state"                  default="overtake"
       doc="overtake only (recovery/observe not yet supported by SQP)"/>
  <arg name="instance_name"          default="rolling_$(arg state)"/>
  <arg name="config_file"            default="$(find overtaking_iy)/config/state_$(arg state).yaml"/>
  <arg name="attach_to_statemachine" default="false"
       doc="false -> /planner/avoidance/otwpnts_observation; true -> real topic."/>
  <arg name="output_topic"           default=""
       doc="Non-empty overrides role remap entirely."/>

  <node pkg="overtaking_iy" type="overtaking_iy_node.py"
        name="$(arg instance_name)" output="screen">
    <rosparam command="load" file="$(arg config_file)"/>

    <!-- Priority: explicit output_topic > attach_to_statemachine > observation. -->
    <remap from="/planner/rolling/otwpnts" to="$(arg output_topic)"
           if="$(eval arg('output_topic') != '')"/>
    <remap from="/planner/rolling/otwpnts" to="/planner/avoidance/otwpnts"
           if="$(eval arg('output_topic') == '' and arg('attach_to_statemachine'))"/>
    <remap from="/planner/rolling/otwpnts" to="/planner/avoidance/otwpnts_observation"
           if="$(eval arg('output_topic') == '' and not arg('attach_to_statemachine'))"/>
  </node>
</launch>
