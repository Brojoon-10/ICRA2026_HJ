<!-- 3D headtohead — controller + state machine + planners -->
<launch>
  <arg name="racecar_version" default="$(env CAR_NAME)" />
  <arg name="ctrl_algo" default="PP" />
  <arg name="LU_table" default="SRX1-0427" />
  <arg name="MAP_mode" default="safe" />
  <arg name="perception" default="False" />
  <arg name="enable_planners" default="True" />
  <arg name="enable_prediction" default="True" />
  <arg name="dynamic_avoidance_mode" default="SQP" />
  <arg name="use_vd_prediction" default="False" />
  <!-- ### HJ : when true, replace spliner / sqp / recovery_spliner with
       sampling_based_planner_3d (state-aware OT + RECOVERY). Default false
       keeps 2D-style planners wired as today. -->
  <arg name="sampling_planner_enable" default="False" />
  ## IY : state_machine_type — "original" or "overtaking"
  <arg name="state_machine_type" default="original" />
  <!-- ### HJ : When empty, sampling_planner reads /map rosparam set by 3d_base_system.launch.
       Set MAP_NAME env var to override. -->
  <arg name="map_name" default="$(optenv MAP_NAME '')"
       doc="Optional map override. Empty → sampling_planner reads /map rosparam set by 3d_base_system.launch." />
  <!-- ### HJ : 3D physics model id (gg_diagrams + vehicle_params + time-optimal raceline).
       Independent of racecar_version (hardware id). Default rc_car_10th_latest. -->
  <arg name="vehicle_name" default="rc_car_10th"
       doc="3D vehicle model id for gg_diagrams / params / raceline. NOT the same as racecar_version." />

  <param name="measure" value="False" />

  <!-- ══════════════════ PERCEPTION (disabled until 3D ready) ══════════════════ -->
  <!--
  <group if="$(arg perception)">
    <include file="$(find stack_master)/launch/perception.launch"/>
  </group>
  -->

  <!-- ══════════════════ CONTROLLER ══════════════════ -->
  <rosparam ns="L1_controller" command="load"
    file="$(find stack_master)/config/$(arg racecar_version)/controller.yaml" />
  <node pkg="controller" name="dyn_controller" type="l1_params_server.py" output="screen" />
  <node pkg="controller" name="controller_manager" type="controller_manager.py" output="screen">
    <param name="LU_table" value="$(arg LU_table)" />
    <param name="ctrl_algo" value="$(arg ctrl_algo)" />
  </node>

  <!-- ══════════════════ STATE MACHINE (3D: 2.5D vel planner) ══════════════════ -->
  <!-- ## IY : original state machine (default) -->
  <group if="$(eval arg('state_machine_type') == 'original')">
    <node pkg="state_machine" type="dynamic_statemachine_server.py" name="dyn_statemachine" output="screen" />
    <node pkg="state_machine" type="3d_state_machine_node.py" name="state_machine">
      <rosparam file="$(find stack_master)/config/state_machine_params.yaml" />
    </node>
  </group>
  <!-- ## IY : lightweight overtaking SM -->
  <group if="$(eval arg('state_machine_type') == 'overtaking')">
    <node pkg="state_machine" type="dynamic_statemachine_server.py" name="dyn_statemachine" output="screen" />
    <node pkg="state_machine" type="fast_sqp_planner_sm.py" name="state_machine" output="screen">
      <rosparam file="$(find stack_master)/config/state_machine_params.yaml" />
      <rosparam file="$(find fast_sqp_planner)/config/state_machine_overtake.yaml" />
    </node>
  </group>

  <!-- ══════════════════ STATE MACHINE PLANNER PARAMS ══════════════════ -->
  <group ns="dyn_planners_statemachine">
    <include file="$(find stack_master)/launch/planners.launch"><arg name="planners" value="global_tracking" /></include>
    <include file="$(find stack_master)/launch/planners.launch"><arg name="planners" value="recovery_planner" /></include>
    <include file="$(find stack_master)/launch/planners.launch"><arg name="planners" value="start_planner" /></include>
    <include file="$(find stack_master)/launch/planners.launch"><arg name="planners" value="static_avoidance_planner" /></include>
    <include file="$(find stack_master)/launch/planners.launch"><arg name="planners" value="dynamic_avoidance_planner" /></include>
  </group>

  <!-- ══════════════════ 3D PLANNERS (enable_planners:=True) ══════════════════ -->
  <!-- ### HJ : legacy planners always active. sampling planner는 observation 전용으로 병렬 기동. -->
  <group if="$(arg enable_planners)">

    <!-- Planner tuning servers (rqt: dyn_planner_tuner/) -->
    <group ns="dyn_planner_tuner">
      <node pkg="recovery_spliner" type="dynamic_recovery_spline_server.py" name="recovery" output="screen" />
      <node pkg="spliner" type="dynamic_spline_server.py" name="static_avoidance" output="screen" />
    </group>

    <!-- Recovery (3D) -->
    <node pkg="recovery_spliner" type="3d_recovery_spliner_node.py" name="recovery_planner_spline"
          output="screen" />

    <!-- Start planner -->
    <node pkg="spliner" type="start_spline_node_v2.py" name="start_planner" output="screen"/>

    <!-- Static Avoidance (3D) — feeds /planner/avoidance/static_otwpnts (SMART_STATIC state) -->
    <node pkg="spliner" type="3d_static_avoidance_node.py" name="planner_spline" output="screen">
      <remap from="/planner/avoidance/otwpnts" to="/planner/avoidance/static_otwpnts"/>
    </node>

  </group>

  <!-- ══════════════════ DYNAMIC AVOIDANCE (3D SQP, enable_planners:=True) ══════════════════ -->
  <!-- ### HJ : SQP owns /planner/avoidance/otwpnts. /sampling_planner/overtake publishes
       to *_observation topics only until trajectory continuity is resolved. -->
  <group if="$(arg enable_planners)">
    <group if="$(eval dynamic_avoidance_mode == 'SQP')">
      <node pkg="sqp_planner" type="dynamic_sqp_server.py" name="dynamic_sqp_tuner_node" output="screen"/>
      <node pkg="sqp_planner" type="3d_sqp_avoidance_node.py" name="planner_sqp" output="screen"/>
      <node pkg="sqp_planner" type="update_waypoints.py" name="waypoint_updater" output="screen"/>
    </group>
  </group>

  <!-- ══════════════════ SAMPLING-BASED PLANNER 3D (observation-only) ══════════════════ -->
  <!-- ### HJ : Observation-only until trajectory continuity is resolved. When
       sampling_planner_enable:=true, /sampling_planner/{overtake,recovery} instances publish
       to /planner/{avoidance/otwpnts,recovery/wpnts}_observation only. Actual driving is owned
       by the legacy sqp / recovery_spliner planners. rqt_reconfigure groups both instances
       under /sampling_planner/ for unified cost / sampling-grid tuning. -->
  <group if="$(arg sampling_planner_enable)">
    <include file="$(find sampling_based_planner_3d)/launch/sampling_planner_multi.launch">
      <arg name="map_name"     value="$(arg map_name)"/>
      <arg name="vehicle_name" value="$(arg vehicle_name)"/>
    </include>
  </group>

  <!-- ══════════════════ GP PREDICTION (3D, enable_prediction:=True) ══════════════════ -->
  <group if="$(arg enable_prediction)">
    <node pkg="gp_traj_predictor" type="dynamic_prediction_server.py" name="dynamic_prediction_tuner_node" output="screen"/>
    <node pkg="gp_traj_predictor" type="3d_opp_prediction.py" name="opponent_propagation_predictor" output="screen">
      <param name="use_vd_prediction" value="$(arg use_vd_prediction)" />
      <param name="obstacle_half_width" value="0.3" />
    </node>
    <node pkg="gp_traj_predictor" type="3d_opponent_trajectory.py" name="OpponentHalflap" output="screen"/>
    <node pkg="gp_traj_predictor" type="gaussian_process_opp_traj.py" name="GP_trajectory" output="screen" launch-prefix="taskset -c 1"/>
    <node pkg="gp_traj_predictor" type="predictor_opponent_trajectory.py" name="Predictor_Opp" output="screen"/>
  </group>

</launch>
